# .gitignore para projeto Java / Maven / Spring Boot
# Mantém arquivos de build e artefatos locais fora do repositório

# Maven
/target/
!.mvn/wrapper/maven-wrapper.jar
.mvn/wrapper/maven-wrapper.jar

# Eclipse
.project
.classpath
.settings/
.bin/

# IntelliJ IDEA
/.idea/
*.iws
*.iml
*.ipr

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
.nb-gradle/

# VS Code
.vscode/

# Logs and temp files
*.log
*.tmp
*.temp
tmp/
temp/
logs/
*.swp

# OS generated files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Environment / sensitive files
.env
.env.*
*.local
/local.properties
/secrets/
*.jks
*.keystore
*.p12

# Build outputs
/build/
out/

# IDE and editor backups
*~
*.bak
*.old
*.orig

# Node and frontend (if present)
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Docker
docker-compose.override.yml
.env.docker

# Generated by tools
generated/
**/generated-sources/
**/generated-test-sources/

# Test reports
/surefire-reports/
/failsafe-reports/

# Application specific
application.properties
application.yml
# Se você tem um application.properties com segredos, mantenha-o local e adicione uma cópia de exemplo
# application.properties.example

# JetBrains Rider
.idea/
*.sln
*.suo

# Gradle (caso haja módulos que usem gradle)
.gradle/
build/

# Misc
coverage/
*.class
*.jar
*.war
*.ear

# Jetty / Tomcat temp
work/**

# CI
.circleci/

# keep gitignore itself
!.gitignore

# Custom excludes que já existiam no arquivo original
HELP.md

# End of file
